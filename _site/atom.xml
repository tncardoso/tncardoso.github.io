    &lt;/tr&gt;
    &lt;tr&gt;
      &lt;td style=&quot;text-align: left&quot;&gt;Random [0.0, 1.0)&lt;/td&gt;
      &lt;td style=&quot;text-align: center&quot;&gt;rnd&lt;/td&gt;
